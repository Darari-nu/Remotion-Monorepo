{
  "name": "remotion-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Remotion workspace for multiple video projects",
  "scripts": {
    "template-gallery": "pnpm --filter @apps/260210_template-gallery dev",
    "lifeismamagoto": "pnpm --filter @apps/260210_lifeismamagoto dev",
    "dev:template": "pnpm --filter @apps/260210_template-gallery dev",
    "dev:life": "pnpm --filter @apps/260210_lifeismamagoto dev",
    "studio:template": "pnpm --filter @apps/260210_template-gallery studio",
    "studio:life": "pnpm --filter @apps/260210_lifeismamagoto studio",
    "voicevox": "pnpm --filter @apps/260122_remotion-voicevox-template start",
    "studio:voicevox": "pnpm --filter @apps/260122_remotion-voicevox-template start",
    "dev:voicevox": "pnpm --filter @apps/260122_remotion-voicevox-template start",
    "yumekui": "pnpm --filter @apps/251206_MV_yumekuibaku dev",
    "studio:yumekui": "pnpm --filter @apps/251206_MV_yumekuibaku dev",
    "lyric-gen": "pnpm --filter @apps/260103_lyric-video-generator start",
    "studio:lyric-gen": "pnpm --filter @apps/260103_lyric-video-generator start",
    "create": "tsx scripts/create-project.ts",
    "render": "tsx scripts/render-app.ts",
    "upgrade:remotion": "tsx scripts/upgrade-remotion.ts",
    "clean": "tsx scripts/clean.ts"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
